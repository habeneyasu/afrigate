# =============================================================================
# Afrigate — Environment Configuration
# Copy to .env and fill in your values.
# =============================================================================

# --- Cerebras (active provider — doc_intel worker) ---
CEREBRAS_API_KEY=your_cerebras_api_key_here
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1
CEREBRAS_MODEL_WORKER=llama3.1-8b
CEREBRAS_MODEL_EVALUATOR=llama3.1-8b

# --- Google Gemini (preferred evaluator provider) ---
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL_WORKER=gemini-2.5-flash
GEMINI_MODEL_EVALUATOR=gemini-1.5-flash

# --- OpenAI (fallback for either agent) ---
OPENAI_API_KEY=your_openai_api_key_here

# --- LangSmith Tracing ---
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=afrigate

# --- Orchestration ---
MAX_ITERATIONS=3

# --- App ---
LOG_LEVEL=INFO
ENVIRONMENT=development
